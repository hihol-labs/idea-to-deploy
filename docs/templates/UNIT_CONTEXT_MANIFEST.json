  ],
  "gates": [
    "acceptanceContract",
    "tddRed",
    "tddGreen",
    "rootCause",
    "specComplianceReview",
    "codeQualityReview",
    "scopeLock",
    "dataAuthenticity",
    "goldenFlows",
