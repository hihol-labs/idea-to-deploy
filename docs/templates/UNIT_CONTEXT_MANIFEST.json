    "branchFinish",
    "learningPromotion",
    "toolCapabilityRegistry"
  ],
  "engineeringDiscipline": {
    "behaviorChange": false,
    "bugfix": false,
    "strictPlan": true,
    "requiresTdd": "behavior changes",
