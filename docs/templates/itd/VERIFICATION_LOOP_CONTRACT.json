{
  "version": 1,
  "enabled": true,
  "policyId": "verification-loop-v1",
  "policySource": "skills/_shared/VERIFICATION_LOOP_POLICY.json",
  "receiptDirectory": ".itd-memory/verification-loop",
  "declaredMachineInputs": [],
  "trustModel": {
    "makerProducesCandidateNotPass": true,
    "harnessExecutesOracle": true,
    "machineOutputRetention": "hashes-only",
    "verifierUsesExactCandidate": true,
    "undeclaredIgnoredWorkspaceInputsAreExcluded": true,
