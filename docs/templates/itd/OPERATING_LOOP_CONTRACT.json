{
  "$schema": "./OPERATING_LOOP_CONTRACT.schema.json",
  "version": 1,
  "policyId": "operating-loop-v1",
  "enabled": false,
  "project": "{{PROJECT_NAME}}",
  "recipes": [],
  "schedulerBindings": [],
  "trustLeases": [],
  "budgets": {
    "maxObservedTokensPerDay": null,
    "maxRunsPerDay": null,
    "maxAttemptsPerItem": 3,
    "softRatio": 0.8,
    "hardRatio": 1.0
  },
  "telemetry": {
    "ledger": ".itd-memory/operating-loop-runs.jsonl",
