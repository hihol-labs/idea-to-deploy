{
  "_comment_1": "Project-level .claude/settings.json template for idea-to-deploy adoption.",
  "_comment_2": "Placed by /adopt in $PROJECT_ROOT/.claude/settings.json — NOT in ~/.claude/settings.json.",
  "_comment_3": "Substitute {{PLUGIN_HOOKS_DIR}} with the resolved plugin hooks directory (default: ~/.claude/plugins/idea-to-deploy/hooks). Legacy sync-to-active.sh installs use ~/.claude/hooks.",
  "_comment_4": "If the user already has .claude/settings.json, /adopt merges hooks entries without duplicating (match by command path). User's existing keys (permissions, env, statusLine, model) are preserved.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "{{PLUGIN_HOOKS_DIR}}/session-open-diagnostic.sh", "timeout": 5 },
          { "type": "command", "command": "{{PLUGIN_HOOKS_DIR}}/pre-flight-check.sh",        "timeout": 5 },
          { "type": "command", "command": "{{PLUGIN_HOOKS_DIR}}/check-skills.sh",            "timeout": 5 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "{{PLUGIN_HOOKS_DIR}}/check-tool-skill.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "{{PLUGIN_HOOKS_DIR}}/check-commit-completeness.sh",   "timeout": 5 },
          { "type": "command", "command": "{{PLUGIN_HOOKS_DIR}}/check-review-before-commit.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "{{PLUGIN_HOOKS_DIR}}/check-skill-completeness.sh", "timeout": 5 }
        ]
      }
    ]
  }
}
